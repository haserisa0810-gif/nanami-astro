{% extends "platform_base.html" %}{% set title = "占いお申込み" %}{% block content %}
<div class="card"><h1>占いお申込み</h1><p class="muted">メニュー選択 → 入力 → 決済案内 → 納品の流れです。</p></div>
{% if error %}<div class="error">{{ error }}</div>{% endif %}
<div class="card">
  <form method="post" action="/order/start">
    <div class="grid">
      <div><label>メニュー</label><select name="menu_id" required>{% for menu in menus %}<option value="{{ menu.id }}">{{ menu.name }} / ¥{{ "{:,}".format(menu.price) }}</option>{% endfor %}</select></div>
      <div><label>お名前</label><input name="user_name" required></div>
      <div><label>ご連絡先（メール推奨）</label><input name="user_contact" placeholder="example@example.com"></div>
      <div><label>生年月日</label><input type="date" name="birth_date" required></div>
      <div><label>出生時間</label><input type="time" name="birth_time"></div>
      <div><label>都道府県（任意）</label><select name="birth_prefecture"><option value="">選択なし</option>{% for pref in prefecture_options %}<option value="{{ pref }}">{{ pref }}</option>{% endfor %}</select></div>
      <div><label>出生地（市区町村など・任意）</label><input name="birth_place" placeholder="足立区 / 横浜市 など"></div>
      <div><label>性別（任意）</label><select name="gender"><option value="">未選択</option><option value="1">女性</option><option value="2">男性</option><option value="3">その他</option><option value="4">回答しない</option></select></div>
    </div>
    <div style="margin-top:12px"><label>ご相談内容（任意）</label><textarea name="consultation_text" placeholder="恋愛、仕事、人間関係など"></textarea></div>
    <p class="muted" style="margin-top:10px">都道府県だけでも受付できます。市区町村まで入力すると、より正確な出生地設定ができます。座標は内部で自動取得し、必要な場合は管理画面で手修正できます。</p>
    <div style="margin-top:14px"><button type="submit">確認画面へ進む</button></div>
  </form>
</div>
{% endblock %}
